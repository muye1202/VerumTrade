# ─────────────────────────────────────────────────────────────
#  Verumtrade - Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in the keys you need.
#
#     cp .env.example .env        # Linux / macOS
#     copy .env.example .env      # Windows
#
#  Only ONE LLM provider key is required to get started.
#  Everything else is optional and can be added later.
# ─────────────────────────────────────────────────────────────


# ─── LLM Providers (pick at least one) ──────────────────────

OPENAI_API_KEY=
# OPENAI_BASE_URL=                 # Custom endpoint (default: https://api.openai.com/v1)

AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_BASE_URL=          # Azure Foundry model endpoint base URL

ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=              # Custom endpoint (e.g. proxy)

GOOGLE_API_KEY=
# Or: GEMINI_API_KEY=

DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=               # Default: https://api.deepseek.com/v1

DASHSCOPE_API_KEY=                  # Qwen / DashScope (qwen3-cn provider)
# DASHSCOPE_BASE_URL=              # Default: https://dashscope.aliyuncs.com/compatible-mode/v1

ZHIPUAI_API_KEY=                    # GLM / ZhipuAI
# ZHIPUAI_BASE_URL=                # Default: https://open.bigmodel.cn/api/paas/v4

OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=             # Default: https://openrouter.ai/api/v1

# Ollama (local models — no API key needed)
# OLLAMA_BASE_URL=                 # Default: http://localhost:11434/v1


# ─── Market Data (optional — extends available data sources) ─

ALPHA_VANTAGE_API_KEY=              # https://www.alphavantage.co/support/#api-key
TWELVE_DATA_API_KEY=                # https://twelvedata.com (free tier: 800 credits/day)
FINNHUB_API_KEY=                    # https://finnhub.io

# Yahoo Finance works out of the box with NO key at all,
# so you can start analysing stocks right away.


# ─── Alpaca Brokerage (optional — for paper / live trading) ──

APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets   # Paper trading (safe default)
APCA_API_DATA_URL=https://data.alpaca.markets         # Market data endpoint

# Alternate env-var names also accepted:
#   ALPACA_API_KEY / ALPACA_SECRET_KEY / ALPACA_API_BASE_URL


# ─── Verumtrade Tuning (all optional — sensible defaults) ─
# VERUMTRADE_* names configure Verumtrade runtime behavior.

# VERUMTRADE_LLM_PROVIDER=openai         # Override default provider
# VERUMTRADE_RESULTS_DIR=./results        # Where reports are saved

# Recursion / tool-call guardrails
# VERUMTRADE_MAX_RECUR_LIMIT=100
# VERUMTRADE_MAX_TOOL_CALLS_PER_ANALYST=8
# VERUMTRADE_MAX_TOOL_CALLS_TOTAL=50
# VERUMTRADE_ANALYST_TOOL_ROUND_CAP=4

# Context budget (prevents 400 errors on providers with strict context windows)
# VERUMTRADE_CONTEXT_BUDGET_MODE=adaptive   # adaptive | compact | off

# Qwen thinking mode
# VERUMTRADE_QWEN_ENABLE_THINKING=false
# VERUMTRADE_QWEN_THINKING_BUDGET=7000

# Anthropic thinking mode
# VERUMTRADE_ANTHROPIC_ENABLE_THINKING=true
# VERUMTRADE_ANTHROPIC_THINKING_BUDGET=1024

# Azure Foundry reasoning mode
# VERUMTRADE_AZURE_FOUNDRY_ENABLE_THINKING=false
# VERUMTRADE_AZURE_FOUNDRY_REASONING_EFFORT=medium  # low | medium | high

# Rate-limit mitigation for deep-think manager nodes
# VERUMTRADE_RESEARCH_MANAGER_MIN_DELAY_S=2.0
# VERUMTRADE_RISK_MANAGER_MIN_DELAY_S=2.0
